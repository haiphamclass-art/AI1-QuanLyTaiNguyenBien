# Reverse Proxy for quanlytainguyen
server {
    listen 80;
    listen [::]:80;
    server_name 113.160.200.14;

    location = /quanlytainguyen {
        return 301 /quanlytainguyen/;
    }

    location ^~ /quanlytainguyen/api/express/ {
        proxy_pass http://localhost:5000/api/express/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /quanlytainguyen/ {
        proxy_pass http://localhost:8082/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
